rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'patrik.soder@gmail.com' ||
        request.auth.token.email == 'hellekk@gmail.com'
      );
    }

    // Full questions doc (includes correctAnswer) — admin only
    match /quizwalk_config/{docId} {
      allow read, write: if isAdmin();
    }

    // Public questions doc (no correctAnswer) — anyone can read, admin writes
    match /quizwalk_config/questions_public {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Team answers
    match /quizwalk_answers/{docId} {
      allow create: if true;
      // Write token must match the one set at creation to prevent one team
      // overwriting another team's document
      allow update: if request.resource.data.writeToken == resource.data.writeToken;
      allow delete: if isAdmin();
      allow read: if true;
    }
  }
}
